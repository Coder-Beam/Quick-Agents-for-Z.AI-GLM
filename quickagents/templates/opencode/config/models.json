{
  "$schema": "./models-schema.json",
  "version": "2.7.0",
  "description": "QuickAgents model configuration optimized for ZhipuAI GLM Coding Plan",
  "strategy": "coding-plan",
  "lockModel": null,
  "default": {
    "primary": "GLM-5",
    "fallback": "GLM-4.7"
  },
  "providers": {
    "zhipuai-coding-plan": {
      "displayName": "智谱AI Coding Plan",
      "description": "专为AI编码打造的订阅套餐，针对编程场景深度优化",
      "baseUrl": "https://open.bigmodel.cn/api/coding/paas/v4",
      "anthropicBaseUrl": "https://open.bigmodel.cn/api/anthropic",
      "models": {
        "GLM-5.1": {
          "id": "GLM-5.1",
          "displayName": "GLM-5.1",
          "description": "最新旗舰模型，Coding Plan全量支持，思考模式增强",
          "contextWindow": 204800,
          "maxTokens": 131072,
          "reasoning": true,
          "capabilities": [
            "coding",
            "agent",
            "thinking",
            "function-call",
            "mcp"
          ],
          "recommended": true,
          "releaseDate": "2025-01"
        },
        "GLM-5": {
          "id": "GLM-5",
          "displayName": "GLM-5",
          "description": "旗舰基座模型，面向Agentic Engineering，Coding能力对齐Claude Opus 4.5",
          "contextWindow": 204800,
          "maxTokens": 131072,
          "reasoning": true,
          "capabilities": [
            "coding",
            "agent",
            "thinking",
            "function-call",
            "mcp"
          ]
        },
        "GLM-4.7": {
          "id": "GLM-4.7",
          "displayName": "GLM-4.7",
          "description": "旗舰版，面向Agentic Coding，Coding能力对齐Claude Sonnet 4.5",
          "contextWindow": 204800,
          "maxTokens": 131072,
          "reasoning": true,
          "capabilities": [
            "coding",
            "agent",
            "thinking",
            "function-call",
            "mcp"
          ]
        },
        "GLM-4.7-FlashX": {
          "id": "GLM-4.7-FlashX",
          "displayName": "GLM-4.7-FlashX",
          "description": "轻量高速版，适合简单任务和快速迭代",
          "contextWindow": 204800,
          "maxTokens": 131072,
          "reasoning": false,
          "capabilities": [
            "coding",
            "quick-response"
          ]
        },
        "GLM-4.5-Air": {
          "id": "GLM-4.5-Air",
          "displayName": "GLM-4.5-Air",
          "description": "轻量版，适合简单任务和快速响应",
          "contextWindow": 128000,
          "maxTokens": 4096,
          "reasoning": false,
          "capabilities": [
            "quick-response"
          ]
        }
      },
      "defaultModel": "GLM-5"
    }
  },
  "categories": {
    "planning": "GLM-5",
    "coding": "GLM-5",
    "consulting": "GLM-5",
    "orchestration": "GLM-5",
    "debug": "GLM-5",
    "review": "GLM-5",
    "testing": "GLM-4.7-FlashX",
    "security": "GLM-5",
    "refactor": "GLM-5",
    "docs": "GLM-4.7",
    "skill": "GLM-4.7",
    "deps": "GLM-4.7-FlashX",
    "perf": "GLM-4.7",
    "cicd": "GLM-4.7-FlashX"
  },
  "agentMapping": {
    "yinglong-init": "planning",
    "cangjie-doc": "docs",
    "fenghou-orchestrate": "orchestration",
    "fenghou-plan": "planning",
    "huodi-skill": "skill",
    "huodi-deps": "deps",
    "kuafu-debug": "debug",
    "lishou-test": "testing",
    "jianming-review": "review",
    "mengzhang-security": "security",
    "gonggu-refactor": "refactor",
    "boyi-consult": "consulting",
    "chisongzi-advise": "consulting",
    "hengge-perf": "perf",
    "hengge-cicd": "cicd"
  },
  "agentOverrides": {},
  "codingPlanConfig": {
    "claudeCodeMapping": {
      "opus": "GLM-5",
      "sonnet": "GLM-4.7",
      "haiku": "GLM-4.5-Air"
    },
    "envVariables": {
      "ANTHROPIC_BASE_URL": "https://open.bigmodel.cn/api/anthropic",
      "API_TIMEOUT_MS": "3000000",
      "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
    }
  },
  "versionUpgrade": {
    "autoDetect": true,
    "checkUrl": "https://docs.bigmodel.cn/llms.txt",
    "upgradePath": {
      "GLM-4": "GLM-4.7",
      "GLM-4.5": "GLM-4.7",
      "GLM-4.6": "GLM-4.7",
      "GLM-4.7": "GLM-5",
      "GLM-5": "GLM-5.1"
    },
    "notifications": true
  },
  "agentRecommendations": {
    "yinglong-init": {
