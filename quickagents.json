{
  "loop_detector": {
    "threshold_strategy": "normal",
    "same_failure_threshold": null,
    "consecutive_failure_threshold": null,
    "max_tool_calls": 100,
    "max_time_seconds": 600,
    "max_retries": 5,
    "backoff_base_ms": 2000,
    "backoff_multiplier": 2,
    "max_backoff_ms": 30000,
    "transient_error_patterns": [
      "timeout",
      "rate_limit",
      "rate limit",
      "network",
      "temporarily",
      "unavailable",
      "connection reset",
      "econnreset",
      "econnrefused",
      "etimedout"
    ],
    "deep_check_interval": 5
  }
}
