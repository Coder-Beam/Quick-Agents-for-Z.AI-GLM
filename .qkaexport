{
  "$schema": "https://quickagents.ai/schemas/qkaexport.json",
  "$meta": {
    "version": "1.0.0",
    "description": "QuickAgents 导出配置 - 自定义排除规则",
    "lastUpdated": "2026-04-04T00:00:00Z"
  },

  "exclude": {
    "dirs": [
      "tests",
      "reference",
      "skills",
      "archive"
    ],

    "root_files": [
      "test_*.py",
      "*_test_report.md",
      "TEST_REPORT.md",
      "test_file_manager.py",
      "test_loop_detector.py",
      "test_memory_manager.py",
      "test_unified_db.py"
    ],

    "docs_files": [
      "Docs/EXAMPLES.md",
      "Docs/API_REFERENCE.md",
      "Docs/AGENT_GUIDE.md",
      "Docs/ARCHITECTURE.md",
      "Docs/HANDOFF_PROMPT.md",
      "Docs/LOOP_DETECTOR_V3_VERIFICATION.md",
      "Docs/OUT_OF_BOX_VALIDATION.md",
      "Docs/QUICKAGENTS_PLAN.md",
      "Docs/SKILLS_INTEGRATION_ANALYSIS.md",
      "Docs/TEST_REPORT.md",
      "Docs/USER_GUIDE.md",
      "Docs/VALIDATION_REPORT.md",
      "Docs/USER_GUIDE.md",
      "Docs/PLUGIN_ARCHITECTURE.md",
      "Docs/PLUGIN_ECOSYSTEM.md",
      "Docs/QUICKAGENTS_VS_SUPERPOWERS.md",
      "Docs/SUPERPOWERS_INTEGRATION_EVALUATION.md"
    ],

    "docs_dirs": [
      "Docs/api",
      "Docs/design",
      "Docs/en",
      "Docs/guide",
      "Docs/guides",
      "Docs/plugins",
      "Docs/research",
      "Docs/specs",
      "Docs/superpowers",
      "Docs/enhancement-analysis"
    ],

    "patterns": [
      "**/*_test_report.md",
      "**/test_*.py",
      "**/*.test.md",
      "**/TEST_REPORT.md"
    ]
  },

  "include": {
    "force_include": [
      "README.md",
      "CHANGELOG.md",
      "RELEASE_NOTES.md"
    ]
  }
}
